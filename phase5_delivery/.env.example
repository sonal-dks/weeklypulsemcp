DELIVERY_MODE=send
DELIVERY_TRIGGER_TOKEN=CHANGE_ME_RANDOM_LONG_TOKEN
EMAIL_RECIPIENT=your_alias@example.com
# Optional overrides. Leave empty to auto-resolve latest phase4 artifacts.
PULSE_PATH=
INSIGHTS_PATH=
GOOGLE_DOC_ID=YOUR_DOC_ID_FROM_GOOGLE_DOCS_URL
GOOGLE_DOC_TITLE=Groww Weekly Product Pulse

# Docs transport:
# - stdio (primary): uses @a-bonus/google-docs-mcp via npx + OAuth
# - http (optional): custom docs endpoint for append
GDOCS_MCP_TRANSPORT=stdio
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
# GDOCS_MCP_ENDPOINT=https://your-docs-endpoint.example/docs/append
# GDOCS_MCP_API_KEY=

# Gmail MCP stdio (required for send in this project)
# Run once: npx -y @gongrzhe/server-gmail-autoauth-mcp auth
# Optional if you store credentials outside default ~/.gmail-mcp/credentials.json
# GMAIL_CREDENTIALS_PATH=/path/to/credentials.json
