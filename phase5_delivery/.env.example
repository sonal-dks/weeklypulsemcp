DELIVERY_MODE=draft_only
EMAIL_RECIPIENT=your_alias@example.com
APPROVED_RECIPIENTS=your_alias@example.com,product-team@example.com
PULSE_PATH=phase4_insights/outputs/pulse_2026-03-24.md
INSIGHTS_PATH=phase4_insights/outputs/insights_2026-03-24.json
OUTPUT_DIR=phase5_delivery/outputs
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2.0
GOOGLE_DOC_ID=YOUR_DOC_ID_FROM_GOOGLE_DOCS_URL
GOOGLE_DOC_TITLE=Groww Weekly Product Pulse
# Required for stdio MCP in practice: use an existing doc ID from the URL (createDocument often hits Permission denied).
# If your shell exports GOOGLE_DOC_ID= (empty), it overrides this file — run: unset GOOGLE_DOC_ID
# Optional: GDOCS_AUTO_CREATE=1 allows MCP to try createDocument when GOOGLE_DOC_ID is empty (needs Drive write access).
# Optional: GDOCS_LAST_WEEK_CACHE=phase5_delivery/outputs/gdocs_last_week_cache.json — written after each successful stdio doc upsert.

# --- Google Docs: @a-bonus/google-docs-mcp (stdio) — https://github.com/a-bonus/google-docs-mcp
# Child process: npx -y @a-bonus/google-docs-mcp (needs Node.js). Authorize once with:
#   GOOGLE_CLIENT_ID=... GOOGLE_CLIENT_SECRET=... npx -y @a-bonus/google-docs-mcp auth
# stdio = @a-bonus/google-docs-mcp (needs Node + OAuth or SA). http = mcp_bridge /docs/append or local fallback.
GDOCS_MCP_TRANSPORT=stdio
GOOGLE_DOCS_MCP_COMMAND=npx
GOOGLE_DOCS_MCP_PACKAGE=@a-bonus/google-docs-mcp
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
# Workspace service account (alternative to OAuth); use with domain-wide delegation when needed:
# SERVICE_ACCOUNT_PATH=/absolute/path/sa.json
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/sa.json
GOOGLE_IMPERSONATE_USER=delegate-user@your-workspace.example.com

# HTTP fallback (e.g. CI / mcp_bridge) when GDOCS_MCP_TRANSPORT=http
# GDOCS_MCP_ENDPOINT=http://127.0.0.1:8080/docs/append
# GDOCS_MCP_API_KEY=

# --- Gmail: GongRzhe Gmail MCP — https://github.com/GongRzhe/Gmail-MCP-Server (archived; npm still works)
# Authorize once: npx -y @gongrzhe/server-gmail-autoauth-mcp auth  (credentials -> ~/.gmail-mcp/credentials.json)
# stdio = same server as Claude/Cursor; http = mcp_bridge POST /gmail/deliver
GMAIL_MCP_TRANSPORT=stdio
GOOGLE_GMAIL_MCP_COMMAND=npx
GOOGLE_GMAIL_MCP_PACKAGE=@gongrzhe/server-gmail-autoauth-mcp
# GMAIL_CREDENTIALS_PATH=/path/to/credentials.json

# GMAIL_MCP_ENDPOINT=http://127.0.0.1:8080/gmail/deliver
# GMAIL_MCP_API_KEY=
