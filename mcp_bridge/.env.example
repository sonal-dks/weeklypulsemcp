# Required: shared secret — must match client GDOCS_MCP_API_KEY and GMAIL_MCP_API_KEY (same value is easiest)
MCP_BRIDGE_API_KEY=replace-with-long-random-secret

# Service account JSON path (local). Cloud Run: mount secret and set env to /secrets/sa.json
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Workspace: user to impersonate for Gmail (required for send/draft via service account).
GMAIL_IMPERSONATE_USER=pulse-bot@yourdomain.com

# Optional: impersonate for Docs (if you use delegation). Leave empty to use the service account
# directly — then share the target Google Doc with the service account email.
DOCS_IMPERSONATE_USER=

GMAIL_USE_IMPERSONATION=true
